# :vim:ft=conf

defaults
logfile ~/log/msmtp.log

account gmail
host smtp.gmail.com
from pablohoffman@gmail.com
auth on
tls on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
user pablohoffman@gmail.com
port 587

account insophia
from pablo@insophia.com
host smtp.gmail.com
auth on
tls on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
user pablo@insophia.com
port 587

account scrapinghub
from pablo@scrapinghub.com
host smtp.gmail.com
auth on
tls on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
user pablo@scrapinghub.com
port 587

account localhost
from prh@prh-laptop
host localhost

account todo: localhost
from todo@prh-laptop

account reminder: localhost
from reminder@prh-laptop

account default: gmail
