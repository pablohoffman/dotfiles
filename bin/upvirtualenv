#!/usr/bin/env python

import os, glob, shutil
from os.path import expanduser, join, exists

VIRTUALENV_DIR = expanduser('~/.virtualenvs')

MODULES = [
    'bpython',
    'twisted',
    'zope',
    'boto',
    'requests',
    'pygments',
    'lxml',
    'numpy',
    'PIL',
    'PyQt4',
    'sip',
    'jinja2',

    'pylint',
    'logilab',

    'IPython',
    'pexpect',
    'decorator',
    'simplegeneric',

    ('scrapy', '~/src/scrapy/scrapy'),
    ('w3lib', '~/src/w3lib/w3lib'),
    ('scrapely', '~/src/scrapely/scrapely'),
    ('scrapylib', '~/src/scrapylib/scrapylib'),
    ('scrapinghub.py', '~/src/python-scrapinghub/scrapinghub.py'),
    ('slybot', '~/src/slybot/slybot'),
]

def get_module_path(name):
    m = __import__(name)
    try:
        return name, m.__path__[0]
    except AttributeError:
        path = m.__file__
        if path.endswith('.so'):
            return name + '.so', path
        else:
            return name + '.py', path.replace('.pyc', '.py')

def main():
    for d in glob.glob('%s/*/lib/python*/site-packages' % VIRTUALENV_DIR):
        gdir = join(d, '_global')
        if exists(gdir):
            shutil.rmtree(gdir)
        os.mkdir(gdir)
        with open(join(d, '_global.pth'), 'w') as f:
            f.write(gdir + '\n')
        for module in MODULES:
            if isinstance(module, tuple):
                mname = module[0]
                mpath = expanduser(module[1])
            else:
                mname, mpath = get_module_path(module)
            target = join(gdir, mname)
            os.symlink(mpath, target)
            print "%s -> %s" % (target, mpath)

if __name__ == '__main__':
    main()
