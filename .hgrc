[paths]
rcfiles = https://hg.insophia.com/rcfiles/pablo/
github = git@github.com:insophia/scrapy.git

[trusted]
users = root, mercurial
ssh = ssh -C

[ui]
ignore = ~/.hgignore
username = Pablo Hoffman <pablo@pablohoffman.com>

[extensions]
hgext.rebase =
hgext.graphlog = 
hgext.mq =
hgext.color =
hgext.hgk =
hgext.fetch =
hgext.purge =
#hgext.patchbomb =
paste = ~/.hgext/paste.py

hgext.bookmarks =
#hggit =

[color]
status.modified = magenta bold
status.added = green bold
status.removed = red bold
status.deleted = cyan bold
status.unknown = black bold
status.ignored = blue bold

[hooks]
#precommit.pylint = cd $(hg root); pylint $(hg st -nma | grep .py); exit 0

[diff]
git=1

[email]
method = /usr/sbin/sendmail

[alias]
paste = paste --dest dpaste.org -u pablo
ipaste = paste --dest dpaste.org --url "https://paste.insophia.com" --usenetrc -u pablo
mpaste = paste --dest pastebin.dixo.net --url "https://dev.mydeco.com/pastebin/" --usenetrc -u pablo
qpaste = paste -r qtip -u pablo
