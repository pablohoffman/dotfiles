escape ^Oo
startup_message off
vbell off
shelltitle sh

# for terminal scroll support
termcapinfo xterm|xterms|xs|rxvt ti@:te@

# linea usar en como status
hardstatus off
hardstatus alwayslastline
hardstatus string '%{= kW}%H %{= kG}[%= %{= kw}%?%-w%?%{r}(%{W}%n*%f%t%?(%u)%?%{r})%{w}%?%+w%?%?%= %{g}]%{W}%c%{g}'
#hardstatus string '%?%-Lw%?(%n*%f%t%?(%u)%?)%?%+Lw%?%?'

# map Alt+x to windows number x
bindkey ^[` select 0 # alt+`
bindkey ^[1 select 1
bindkey ^[2 select 2
bindkey ^[3 select 3
bindkey ^[4 select 4
bindkey ^[5 select 5
bindkey ^[6 select 6
bindkey ^[7 select 7
bindkey ^[8 select 8
bindkey ^[9 select 9

bindkey ^[r title

